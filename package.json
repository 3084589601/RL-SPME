{
  "name": "robotics-lab-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && node scripts/sync-public-media.js && node scripts/generate-media-manifest.js && node scripts/build-database.js && next build",
    "start": "next start",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "setup": "prisma db push && tsx prisma/seed.ts",
    "optimize:images": "node scripts/optimize-uploads.js",
    "optimize:media": "node scripts/optimize-folder-media.js",
    "optimize:all": "node scripts/optimize-folder-media.js && node scripts/optimize-uploads.js",
    "deploy": "npm run build && npm run start"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@aws-sdk/client-s3": "^3.1082.0",
    "@aws-sdk/s3-request-presigner": "^3.1082.0",
    "@prisma/client": "^6.3.1",
    "archiver": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.474.0",
    "next": "^15.1.6",
    "next-auth": "^4.24.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.1",
    "sharp": "^0.35.1",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.3",
    "@types/archiver": "^8.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "prisma": "^6.3.1",
    "tailwindcss": "^4.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
